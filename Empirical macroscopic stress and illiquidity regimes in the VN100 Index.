import pandas as pd
import matplotlib.pyplot as plt

# 1. Load the data that was already generated by the earlier script
# Make sure 'vn100_index_fallback_metrics.csv' is in your folder
df = pd.read_csv("vn100_index_fallback_metrics.csv")
df['Date'] = pd.to_datetime(df['Date'])
df = df.set_index('Date')

# 2. Generate Figure 3
fig, ax1 = plt.subplots(figsize=(12, 5), dpi=200)

# Plot Macroscopic Illiquidity
line1, = ax1.plot(
    df.index, 
    df['RollILLIQ'], 
    color='crimson', 
    linewidth=1.8, 
    label=r"Rolling Macroscopic Illiquidity ($L_{emp,t}$)"
)
ax1.set_xlabel("Date", fontsize=11)
ax1.set_ylabel(r"Illiquidity Proxy ($L_{emp,t}$)", color='crimson', fontsize=11)
ax1.tick_params(axis='y', labelcolor='crimson')

# Plot Systemic Stress Score on secondary axis
ax2 = ax1.twinx()
line2, = ax2.plot(
    df.index, 
    df['StressScore'], 
    color='black', 
    linewidth=1.5, 
    alpha=0.7, 
    label="Aggregate Systemic Stress Score"
)
ax2.set_ylabel("Systemic Stress Score (Z-Score)", color='black', fontsize=11)
ax2.tick_params(axis='y', labelcolor='black')

# Formatting the Legend
lines = [line1, line2]
labels = [l.get_label() for l in lines]
ax1.legend(
    lines, labels, 
    loc="upper left", 
    framealpha=0.9,
    fontsize=9, 
    labelspacing=0.3, 
    handlelength=1.2, 
    borderpad=0.4
)

# Title and Grid
ax1.set_title(
    "Figure 3. Empirical macroscopic stress and illiquidity regimes in the VN100 Index", 
    pad=12, 
    fontweight='bold'
)
ax1.grid(True, linestyle=":", alpha=0.5)

plt.tight_layout()
plt.savefig("Figure3_VN100_Macroscopic_Stress.png", bbox_inches="tight")
plt.show()

print("Figure 3 generated and saved as 'Figure3_VN100_Macroscopic_Stress.png'")
